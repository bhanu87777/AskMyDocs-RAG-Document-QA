# ─────────────────────────────────────────────────────────────
# AskMyDocs — environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection.
# URL-encode any special characters in the password (e.g. # -> %23, @ -> %40).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/askmydocs?schema=public"

# Auth.js / NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Claude API key (optional). Enables Claude for grounded answer generation.
# Get one at https://console.anthropic.com. Leave empty to try Gemini next.
ANTHROPIC_API_KEY=""

# Google Gemini API key (optional, FREE — no credit card).
# Get one at https://aistudio.google.com/apikey. Used when ANTHROPIC_API_KEY is
# empty. If BOTH keys are empty, an extractive fallback returns the retrieved
# passages — so the RAG pipeline is demonstrable end-to-end for free.
GEMINI_API_KEY=""

# Optional: override the answer model.
# ANSWER_MODEL="claude-sonnet-5"       # Claude (when ANTHROPIC_API_KEY is set)
# GEMINI_MODEL="gemini-flash-latest"   # Gemini (when GEMINI_API_KEY is set)
