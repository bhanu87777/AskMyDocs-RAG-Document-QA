# ─────────────────────────────────────────────────────────────
# AskMyDocs — environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection.
# URL-encode any special characters in the password (e.g. # -> %23, @ -> %40).
# DATABASE_URL = pooled connection (used at runtime).
# DIRECT_URL   = direct connection (used by Prisma CLI: migrate / db push).
# On Neon: DATABASE_URL = the "-pooler" host, DIRECT_URL = the non-pooler host.
# Drop "&channel_binding=require" from Neon strings — keep only ?sslmode=require.
# Locally, set both to the same local Postgres value.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/askmydocs?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/askmydocs?schema=public"

# Auth.js / NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Claude API key (optional). Enables Claude for grounded answer generation.
# Get one at https://console.anthropic.com. Leave empty to try Gemini next.
ANTHROPIC_API_KEY=""

# Google Gemini API key (FREE — no credit card). Get one at
# https://aistudio.google.com/apikey.
# REQUIRED: embeddings (text-embedding-004) and OCR run through Gemini, so the
# app needs this key to ingest documents and answer questions. It also powers
# grounded answer generation when ANTHROPIC_API_KEY is empty.
GEMINI_API_KEY=""

# Optional: override the answer model.
# ANSWER_MODEL="claude-sonnet-5"       # Claude (when ANTHROPIC_API_KEY is set)
# GEMINI_MODEL="gemini-flash-latest"   # Gemini (when GEMINI_API_KEY is set)
